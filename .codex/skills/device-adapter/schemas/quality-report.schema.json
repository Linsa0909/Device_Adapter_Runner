{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["report_version", "context_id", "stage", "producer_role", "status", "source_fingerprint", "evidence", "findings", "created_at"],
  "properties": {
    "report_version": {"const": 1},
    "context_id": {"type": "string", "minLength": 1},
    "stage": {"type": "string", "pattern": "^stage"},
    "producer_role": {"type": "string", "minLength": 1},
    "status": {"enum": ["PASS", "FAIL", "BLOCKED", "NOT_RUN"]},
    "source_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "evidence": {"type": "array", "minItems": 1},
    "findings": {"type": "array"},
    "created_at": {"type": "string", "minLength": 1}
  }
}
