{
  "stage0_env_check": {
    "agent": "device-adapter-runtime",
    "outputs": []
  },
  "stage1_context_intake": {
    "agent": "context-mapper",
    "outputs": [
      "ops/contexts/<context_id>.context.md",
      "ops/contexts/<context_id>.manifest.json"
    ]
  },
  "stage2_docs_inventory": {
    "agent": "extract_docs.py",
    "outputs": [
      "ops/contexts/<context_id>.docs_inventory.json"
    ]
  },
  "stage2_docs_extract": {
    "agent": "extract_docs.py",
    "outputs": [
      "ops/artifacts/docs/<context_id>/extraction_report.json",
      "ops/artifacts/docs/<context_id>/text/*.txt"
    ]
  },
  "stage3_docs_coverage": {
    "agent": "docs-intake-agent",
    "outputs": [
      "ops/contexts/<context_id>.docs_coverage.json"
    ]
  },
  "stage4_functional_chain_check": {
    "agent": "acceptance-planner-agent",
    "outputs": [
      "ops/contexts/<context_id>.functional_chain.json",
      "ops/contexts/<context_id>.dependency_checklist.json",
      "ops/artifacts/<context_id>.dependency_gaps.md",
      "ops/artifacts/<context_id>.functional_chain_check.json"
    ]
  },
  "stage4_capability_model": {
    "agent": "capability-modeler-agent",
    "outputs": [
      "ops/contexts/<context_id>.device_spec.json",
      "ops/contexts/<context_id>.plugin_contract.json"
    ]
  },
  "stage4a_sdk_contract_prepare": {
    "agent": "prepare_plugin_contract.py",
    "outputs": [
      "ops/contexts/<context_id>.plugin_contract.json"
    ]
  },
  "stage5_deployment_plan": {
    "agent": "deployment-planner-agent",
    "outputs": [
      "ops/contexts/<context_id>.deployment_plan.json",
      "ops/contexts/<context_id>.deployment.yaml"
    ]
  },
  "stage6_dependency_audit": {
    "agent": "sdk-dependency-auditor-agent",
    "outputs": [
      "ops/contexts/<context_id>.dependency_plan.json",
      "ops/artifacts/<context_id>.dependency_validation.json"
    ]
  },
  "stage7_spec_validate": {
    "agent": "spec-validator-agent",
    "outputs": [
      "ops/artifacts/<context_id>.spec_validation.json"
    ]
  },
  "stage8_yaml_generate": {
    "agent": "yaml-writer-agent",
    "outputs": [
      "adapter_plugins/<adapter>/model/devices/<adapter>.device.yaml",
      "adapter_plugins/<adapter>/config/<adapter>.json"
    ]
  },
  "stage10_adapter_codegen": {
    "agent": "hal-adapter-builder",
    "outputs": [
      "adapter_plugins/<adapter>/include/",
      "adapter_plugins/<adapter>/src/",
      "adapter_plugins/<adapter>/CMakeLists.txt",
      "ops/artifacts/<context_id>.transport_validation.json"
    ]
  },
  "stage6a_sdk_package": {
    "agent": "sdk-packager-agent",
    "outputs": [
      "ops/artifacts/<context_id>.sdk_package.json",
      "ops/artifacts/logs/<context_id>_sdk_package.log",
      "<sdk_output_dir>/hal_adapter_sdk_v<sdk_version>",
      "<sdk_output_dir>/hal_adapter_sdk_v<sdk_version>.tar.gz"
    ]
  },
  "stage6a_target_hal_build": {
    "agent": "sdk-packager-agent",
    "outputs": [
      "ops/artifacts/<context_id>.target_sdk_package.json",
      "ops/artifacts/<context_id>.remote_environment.txt",
      "ops/artifacts/<context_id>.platform_library_audit.txt",
      "ops/artifacts/<context_id>.remote_source_fingerprint.txt",
      "ops/artifacts/<context_id>.sdk_container_image.txt",
      "ops/artifacts/<context_id>.target_sdk_validation.txt",
      "ops/artifacts/logs/<context_id>_target_sdk_package.log",
      "<sdk_output_dir>/hal_adapter_sdk_v<sdk_version>.tar.gz"
    ]
  },
  "stage6a_sdk_check": {
    "agent": "sdk-dependency-auditor-agent",
    "outputs": [
      "ops/contexts/<context_id>.sdk_inventory.json",
      "ops/artifacts/<context_id>.sdk_check.json"
    ]
  },
  "stage6b_sdk_validate": {
    "agent": "sdk-packager-agent",
    "outputs": [
      "ops/artifacts/<context_id>.sdk_validation.json",
      "ops/artifacts/logs/<context_id>_sdk_validation.log",
      "ops/artifacts/sdk-validation/<context_id>/install/adapters/libhal_adapter_minimal.so"
    ]
  },
  "stage10c_plugin_build": {
    "agent": "plugin-builder-agent",
    "outputs": [
      "ops/artifacts/<context_id>.plugin_build.json",
      "build/<adapter>-package/adapters/libhal_adapter_<adapter>.so"
    ]
  },
  "stage10c_target_plugin_build": {
    "agent": "plugin-builder-agent",
    "outputs": [
      "ops/artifacts/<context_id>.target_plugin_build.json",
      "ops/artifacts/<context_id>.target_plugin_ldd.txt",
      "ops/artifacts/<context_id>.container_environment.txt",
      "ops/artifacts/logs/<context_id>_target_plugin_build.log",
      "build/<adapter>-package/adapters/libhal_adapter_<adapter>.so"
    ]
  },
  "stage11_plugin_verify": {
    "agent": "verification-agent",
    "outputs": [
      "ops/artifacts/<context_id>.model_lint.json",
      "ops/artifacts/<context_id>.abi_validation.json",
      "ops/artifacts/<context_id>.plugin_declaration_validation.json",
      "ops/artifacts/<context_id>.elf_arch_validation.json",
      "ops/artifacts/<context_id>.dependency_closure.json",
      "ops/artifacts/<context_id>.config_validation.json",
      "ops/artifacts/<context_id>.source_contract_validation.json",
      "ops/artifacts/<context_id>.binding_coverage.json",
      "ops/artifacts/<context_id>.fastpath_coverage.json",
      "ops/artifacts/<context_id>.forbidden_files.json",
      "ops/artifacts/<context_id>.multi_instance_validation.json"
    ]
  },
  "stage10a_tdd_evidence": {
    "agent": "hal-adapter-builder",
    "outputs": [
      "ops/artifacts/<context_id>.tdd_report.json"
    ]
  },
  "stage10b_runtime_materialize": {
    "agent": "device-adapter-runtime",
    "outputs": [
      "Dockerfile",
      "docker-compose.yml",
      ".dockerignore",
      "run.sh",
      "ops/contexts/<context_id>.manifest.json",
      "ops/artifacts/<context_id>.package_files.txt"
    ]
  },
  "stage11a_independent_verification": {
    "agent": "verification-agent",
    "outputs": [
      "ops/artifacts/<context_id>.verification_report.json",
      "ops/artifacts/<context_id>.quality_gate_report.json"
    ]
  },
  "stage11b_cpp_review": {
    "agent": "verification-agent",
    "outputs": [
      "ops/artifacts/<context_id>.c_review_report.json",
      "ops/artifacts/c-review/<context_id>-stage11b/context.md",
      "ops/artifacts/c-review/<context_id>-stage11b/plan.json",
      "ops/artifacts/c-review/<context_id>-stage11b/findings/**",
      "ops/artifacts/c-review/<context_id>-stage11b/coverage/**",
      "ops/artifacts/c-review/<context_id>-stage11b/REPORT.md",
      "ops/artifacts/c-review/<context_id>-stage11b/REPORT.sarif"
    ]
  },
  "stage11c_differential_review": {
    "agent": "verification-agent",
    "outputs": [
      "ops/artifacts/<context_id>.differential_review_report.json"
    ]
  },
  "stage11d_human_approval": {
    "agent": "human",
    "outputs": [
      "ops/artifacts/<context_id>.human_approval.json"
    ]
  },
  "stage12_package_manifest": {
    "agent": "package-builder",
    "outputs": [
      "ops/artifacts/<context_id>.package_manifest.json",
      "ops/artifacts/<context_id>_adapter_plugin.tar.gz"
    ]
  },
  "stage13_package_verify": {
    "agent": "package-builder",
    "outputs": [
      "ops/artifacts/<context_id>.package_verify.json"
    ]
  },
  "stage14_docker_build_x86_optional": {
    "agent": "docker-builder",
    "outputs": [
      "ops/artifacts/<context_id>_amd64_image.tar"
    ]
  },
  "stage15_docker_build_arm64": {
    "agent": "docker-builder",
    "outputs": [
      "ops/artifacts/<context_id>_arm64_image.tar"
    ]
  },
  "stage16_image_verify": {
    "agent": "docker-builder",
    "outputs": [
      "ops/artifacts/<context_id>_<arch>_image_inspect.json"
    ]
  },
  "stage17_remote_transfer": {
    "agent": "remote-deployer",
    "outputs": [
      "ops/artifacts/logs/"
    ]
  },
  "stage18_remote_prepare": {
    "agent": "remote-deployer",
    "outputs": [
      "ops/artifacts/logs/"
    ]
  },
  "stage19_remote_device_probe": {
    "agent": "remote-tester",
    "outputs": [
      "ops/artifacts/logs/"
    ]
  },
  "stage20_remote_run": {
    "agent": "remote-tester",
    "outputs": [
      "ops/artifacts/logs/"
    ]
  },
  "stage21_remote_test": {
    "agent": "remote-tester",
    "outputs": [
      "ops/artifacts/logs/"
    ]
  },
  "stage22_collect_logs": {
    "agent": "remote-tester",
    "outputs": [
      "ops/artifacts/logs/"
    ]
  },
  "stage23_failure_classification": {
    "agent": "failure-debugger",
    "outputs": [
      "ops/artifacts/last_failure.json",
      "ops/artifacts/<context_id>.remediation_plan.json"
    ]
  }
}
