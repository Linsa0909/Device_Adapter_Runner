{
  "schema_version": "1.0",
  "default": {
    "read_allowlist": ["**"],
    "write_allowlist": ["ops/artifacts/**", "ops/contexts/**"],
    "write_denylist": [".git/**"],
    "diff_budget": {
      "max_modified_files": 50,
      "max_changed_lines": 5000
    }
  },
  "stages": {
    "stage9_pre_adapt_verification": {
      "agent": "adapter-test-designer-agent",
      "write_allowlist": ["adapter_plugins/{adapter_type}/tests/**", "ops/artifacts/**"],
      "write_denylist": ["adapter_plugins/{adapter_type}/src/**", "adapter_plugins/{adapter_type}/include/**", "src/**"]
    },
    "stage9a_test_design": {
      "agent": "adapter-test-designer-agent",
      "write_allowlist": ["adapter_plugins/{adapter_type}/tests/**", "ops/artifacts/**"],
      "write_denylist": ["adapter_plugins/{adapter_type}/src/**", "adapter_plugins/{adapter_type}/include/**", "src/**"]
    },
    "stage1_context_intake": {
      "agent": "context-mapper",
      "write_allowlist": [
        "ops/contexts/{context_id}.context.md",
        "ops/contexts/{context_id}.manifest.json",
        "ops/contexts/{context_id}.plugin_contract.json",
        "ops/artifacts/{context_id}.package_files.txt",
        "ops/artifacts/**"
      ],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "CMakeLists.txt"]
    },
    "stage2_docs_extract": {
      "agent": "extract_docs.py",
      "write_allowlist": [
        "ops/contexts/{context_id}.docs_inventory.json",
        "ops/artifacts/docs/{context_id}/**",
        "ops/artifacts/last_failure.json"
      ],
      "write_denylist": ["docs/**", "src/**", "Dockerfile", "docker-compose.yml", "CMakeLists.txt"]
    },
    "stage4_capability_model": {
      "agent": "capability-modeler-agent",
      "write_allowlist": [
        "ops/contexts/{context_id}.device_spec.json",
        "ops/contexts/{context_id}.plugin_contract.json",
        "ops/artifacts/**"
      ],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "CMakeLists.txt"]
    },
    "stage4a_sdk_contract_prepare": {
      "agent": "prepare_plugin_contract.py",
      "write_allowlist": [
        "ops/contexts/{context_id}.plugin_contract.json",
        "ops/artifacts/**"
      ],
      "write_denylist": ["src/**", "adapter_plugins/**", "Dockerfile", "docker-compose.yml", "CMakeLists.txt"]
    },
    "stage4_functional_chain_check": {
      "agent": "acceptance-planner-agent",
      "write_allowlist": [
        "ops/contexts/{context_id}.functional_chain.json",
        "ops/contexts/{context_id}.dependency_checklist.json",
        "ops/artifacts/{context_id}.dependency_gaps.md",
        "ops/artifacts/{context_id}.functional_chain_check.json",
        "ops/artifacts/**"
      ],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "CMakeLists.txt"]
    },
    "stage5_deployment_plan": {
      "agent": "deployment-planner-agent",
      "write_allowlist": [
        "ops/contexts/{context_id}.deployment_plan.json",
        "ops/contexts/{context_id}.deployment.yaml",
        "ops/contexts/{context_id}.device_spec.json",
        "ops/artifacts/**"
      ],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "CMakeLists.txt"]
    },
    "stage6_dependency_audit": {
      "agent": "sdk-dependency-auditor-agent",
      "write_allowlist": [
        "ops/contexts/{context_id}.dependency_plan.json",
        "ops/contexts/{context_id}.device_spec.json",
        "ops/artifacts/**"
      ],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "CMakeLists.txt"]
    },
    "stage7_spec_validate": {
      "agent": "spec-validator-agent",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "CMakeLists.txt", "ops/contexts/**"]
    },
    "stage8_yaml_generate": {
      "agent": "yaml-writer-agent",
      "write_allowlist": [
        "adapter_plugins/**",
        "ops/artifacts/**"
      ],
      "write_denylist": [
        "Dockerfile",
        "docker-compose.yml",
        "CMakeLists.txt",
        "src/**",
        "**/*.capability.yaml",
        "ops/contexts/{context_id}.device_spec.json"
      ],
      "diff_budget": {
        "max_modified_files": 8,
        "max_changed_lines": 800
      }
    },
    "stage10_adapter_codegen": {
      "agent": "hal-adapter-builder",
      "write_allowlist": [
        "adapter_plugins/**",
        "ops/artifacts/**"
      ],
      "write_denylist": [
        "src/**",
        "adapter_plugins/{adapter_type}/tests/**",
        "**/*.capability.yaml",
        "Dockerfile",
        "docker-compose.yml",
        "ops/contexts/{context_id}.device_spec.json"
      ],
      "diff_budget": {
        "max_modified_files": 20,
        "max_changed_lines": 2000
      }
    },
    "stage6a_sdk_package": {
      "agent": "sdk-packager-agent",
      "write_allowlist": [
        "build/**",
        "ops/artifacts/**"
      ],
      "write_denylist": [
        "src/**",
        "adapter_plugins/**",
        "ops/contexts/**",
        "Dockerfile",
        "docker-compose.yml"
      ]
    },
    "stage6a_target_hal_build": {
      "agent": "sdk-packager-agent",
      "write_allowlist": ["build/**", "ops/artifacts/**"],
      "write_denylist": ["src/**", "adapter_plugins/**", "ops/contexts/**", "Dockerfile", "docker-compose.yml"]
    },
    "stage6a_sdk_check": {
      "agent": "sdk-dependency-auditor-agent",
      "write_allowlist": [
        "ops/contexts/{context_id}.sdk_inventory.json",
        "ops/artifacts/{context_id}.sdk_check.json",
        "ops/artifacts/**"
      ],
      "write_denylist": ["src/**", "adapter_plugins/**", "Dockerfile", "docker-compose.yml"]
    },
    "stage6b_sdk_validate": {
      "agent": "sdk-packager-agent",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "adapter_plugins/**", "build/**", "ops/contexts/**", "Dockerfile", "docker-compose.yml"]
    },
    "stage10c_plugin_build": {
      "agent": "plugin-builder-agent",
      "write_allowlist": ["build/**", "ops/artifacts/**"],
      "write_denylist": ["src/**", "adapter_plugins/**", "ops/contexts/**", "Dockerfile", "docker-compose.yml"]
    },
    "stage10c_target_plugin_build": {
      "agent": "plugin-builder-agent",
      "write_allowlist": ["build/**", "ops/artifacts/**"],
      "write_denylist": ["src/**", "adapter_plugins/**", "ops/contexts/**", "Dockerfile", "docker-compose.yml"]
    },
    "stage11_plugin_verify": {
      "agent": "verification-agent",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "adapter_plugins/**", "build/**", "ops/contexts/**"]
    },
    "stage10a_tdd_evidence": {
      "agent": "hal-adapter-builder",
      "write_allowlist": ["ops/artifacts/{context_id}.tdd_report.json", "ops/artifacts/**"],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "ops/contexts/**"]
    },
    "stage10b_runtime_materialize": {
      "agent": "device-adapter-runtime",
      "write_allowlist": [
        "Dockerfile",
        "docker-compose.yml",
        ".dockerignore",
        "run.sh",
        "config.env",
        "install.sh",
        "status.sh",
        "view.sh",
        "DEPLOY.md",
        "ops/scripts/**",
        "ops/contexts/{context_id}.manifest.json",
        "ops/artifacts/**"
      ],
      "write_denylist": ["src/**"]
    },
    "stage11a_independent_verification": {
      "agent": "verification-agent",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "ops/contexts/**"]
    },
    "stage11b_cpp_review": {
      "agent": "verification-agent",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "ops/contexts/**"]
    },
    "stage11c_differential_review": {
      "agent": "verification-agent",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "ops/contexts/**"]
    },
    "stage11d_human_approval": {
      "agent": "human",
      "write_allowlist": ["ops/artifacts/{context_id}.human_approval.json", "ops/artifacts/{context_id}.quality_gate_report.json", "ops/artifacts/**"],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "ops/contexts/**"]
    },
    "stage12_package_manifest": {
      "agent": "package-builder",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "ops/contexts/**", "Dockerfile", "docker-compose.yml", ".dockerignore", "run.sh", "config.env", "install.sh", "status.sh", "view.sh", "DEPLOY.md"]
    },
    "stage13_package_verify": {
      "agent": "package-builder",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "ops/contexts/**"]
    },
    "stage14_docker_build_x86_optional": {
      "agent": "docker-builder",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "ops/contexts/**"]
    },
    "stage15_docker_build_arm64": {
      "agent": "docker-builder",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "ops/contexts/**"]
    },
    "stage16_image_verify": {
      "agent": "docker-builder",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "ops/contexts/**"]
    },
    "stage17_remote_transfer": {
      "agent": "remote-deployer",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "ops/contexts/**", "Dockerfile", "docker-compose.yml"]
    },
    "stage18_remote_prepare": {
      "agent": "remote-deployer",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "ops/contexts/**", "Dockerfile", "docker-compose.yml"]
    },
    "stage19_remote_device_probe": {
      "agent": "remote-tester",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "ops/contexts/**"]
    },
    "stage20_remote_run": {
      "agent": "remote-tester",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "ops/contexts/**"]
    },
    "stage21_remote_test": {
      "agent": "remote-tester",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "ops/contexts/**"]
    },
    "stage22_collect_logs": {
      "agent": "remote-tester",
      "write_allowlist": ["ops/artifacts/**"],
      "write_denylist": ["src/**", "ops/contexts/**"]
    },
    "stage23_failure_classification": {
      "agent": "failure-debugger",
      "write_allowlist": [
        "ops/artifacts/last_failure.json",
        "ops/artifacts/*remediation_plan.json",
        "ops/artifacts/**"
      ],
      "write_denylist": ["src/**", "Dockerfile", "docker-compose.yml", "ops/contexts/**"]
    }
  }
}
